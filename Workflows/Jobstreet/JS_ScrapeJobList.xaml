    <ui:InvokeCode ContinueOnError="{x:Null}" DisplayName="Regex extract job links from HTML" sap2010:WorkflowViewState.IdRef="InvokeCode_1" Code="Dim baseUrl As String = &quot;https://ph.jobstreet.com&quot;&#xD;&#xA;Dim anchorRx As New System.Text.RegularExpressions.Regex(&quot;&lt;a[^&gt;]+&gt;&quot;, System.Text.RegularExpressions.RegexOptions.IgnoreCase)&#xD;&#xA;Dim hrefRx As New System.Text.RegularExpressions.Regex(&quot;href=&quot;&quot;([^&quot;&quot;]*)&quot;&quot;&quot;, System.Text.RegularExpressions.RegexOptions.IgnoreCase)&#xD;&#xA;Dim jobIdRx As New System.Text.RegularExpressions.Regex(&quot;/job/(\d+)&quot;, System.Text.RegularExpressions.RegexOptions.IgnoreCase)&#xD;&#xA;&#xD;&#xA;Dim matches = anchorRx.Matches(html)&#xD;&#xA;Dim seen As New HashSet(Of String)&#xD;&#xA;&#xD;&#xA;For Each m As System.Text.RegularExpressions.Match In matches&#xD;&#xA;    Dim tag As String = m.Value&#xD;&#xA;    If tag.Contains(&quot;data-automation=&quot;&quot;job-list-view-job-link&quot;&quot;&quot;) Then&#xD;&#xA;        Dim hrefMatch = hrefRx.Match(tag)&#xD;&#xA;        If hrefMatch.Success Then&#xD;&#xA;            Dim rawHref As String = hrefMatch.Groups(1).Value.Replace(&quot;&amp;amp;&quot;, &quot;&amp;&quot;)&#xD;&#xA;            Dim idMatch = jobIdRx.Match(rawHref)&#xD;&#xA;            If idMatch.Success Then&#xD;&#xA;                Dim jobId As String = idMatch.Groups(1).Value&#xD;&#xA;                If Not seen.Contains(jobId) Then&#xD;&#xA;                    seen.Add(jobId)&#xD;&#xA;                    ' Construct final URL using the raw href from the tag '&#xD;&#xA;                    If rawHref.StartsWith(&quot;/&quot;) Then&#xD;&#xA;                        links.Add(baseUrl &amp; rawHref)&#xD;&#xA;                    Else&#xD;&#xA;                        links.Add(rawHref)&#xD;&#xA;                    End If&#xD;&#xA;                End If&#xD;&#xA;            End If&#xD;&#xA;        End If&#xD;&#xA;    End If&#xD;&#xA;Next">
