    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Parse các format thời gian đăng phổ biến của LinkedIn&#xD;&#xA;Dim raw As String = If(str_PostedRaw, String.Empty).ToLowerInvariant.Trim&#xD;&#xA;Dim result As DateTime = DateTime.Now&#xD;&#xA;Dim numberMatch = System.Text.RegularExpressions.Regex.Match(raw, &quot;\d+&quot;)&#xD;&#xA;Dim amount As Integer = If(numberMatch.Success, Integer.Parse(numberMatch.Value), 0)&#xD;&#xA;&#xD;&#xA;If raw.Contains(&quot;just now&quot;) OrElse raw.Contains(&quot;today&quot;) Then&#xD;&#xA;    result = DateTime.Now&#xD;&#xA;ElseIf raw.Contains(&quot;yesterday&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddDays(-1)&#xD;&#xA;ElseIf raw.Contains(&quot;minute&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddMinutes(-Math.Max(amount, 1))&#xD;&#xA;ElseIf raw.Contains(&quot;hour&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddHours(-Math.Max(amount, 1))&#xD;&#xA;ElseIf raw.Contains(&quot;day&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddDays(-Math.Max(amount, 1))&#xD;&#xA;ElseIf raw.Contains(&quot;week&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddDays(-7 * Math.Max(amount, 1))&#xD;&#xA;ElseIf raw.Contains(&quot;month&quot;) Then&#xD;&#xA;    result = DateTime.Now.AddMonths(-Math.Max(amount, 1))&#xD;&#xA;End If&#xD;&#xA;&#xD;&#xA;str_PostedAt = result.ToString(&quot;yyyy-MM-dd HH:mm:ss&quot;)" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="483.2,196.8" sap2010:WorkflowViewState.IdRef="InvokeCode_2">
