                        </Assign.To>
                        <Assign.Value>
                          <InArgument x:TypeArguments="x:Int32">[int_Skipped + 1]</InArgument>
                        </Assign.Value>
                      </Assign>
                    </Sequence>
                  </If.Else>
                </If>
              </Sequence>
            </TryCatch.Try>
            <TryCatch.Catches>
